{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync/google-sheets",
      "schedule": "0 17 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow, noarchive, nosnippet, noimageindex",
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "same-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), browsing-topics=()",
        "Content-Security-Policy": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co"
      },
      "continue": true
    },
    {
      "src": "/api/data/([^/]+)",
      "dest": "/api/data/[table]?table=$1"
    },
    {
      "src": "/api/import/([^/]+)",
      "dest": "/api/import/[entity]?entity=$1"
    },
    {
      "src": "/api/templates/([^/]+)",
      "dest": "/api/templates/[entity]?entity=$1"
    },
    {
      "src": "/api/export/([^/]+)",
      "dest": "/api/export/[kind]?kind=$1"
    },
    {
      "src": "/api/operations/([^/]+)",
      "dest": "/api/operations/[action]?action=$1"
    },
    {
      "src": "/api/users/([^/]+)",
      "dest": "/api/users/[id]?id=$1"
    },
    {
      "src": "/api/users",
      "dest": "/api/users/[id]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
