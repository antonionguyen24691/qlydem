{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/data/([^/]+)",
      "dest": "/api/data/[table]"
    },
    {
      "src": "/api/import/([^/]+)",
      "dest": "/api/import/[entity]"
    },
    {
      "src": "/api/templates/([^/]+)",
      "dest": "/api/templates/[entity]"
    },
    {
      "src": "/api/users/([^/]+)",
      "dest": "/api/users/[id]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
