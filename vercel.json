{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync/google-sheets",
      "schedule": "0 17 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "same-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), browsing-topics=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/data/([^/]+)",
      "dest": "/api/data/[table]?table=$1"
    },
    {
      "src": "/api/import/([^/]+)",
      "dest": "/api/import/[entity]?entity=$1"
    },
    {
      "src": "/api/templates/([^/]+)",
      "dest": "/api/templates/[entity]?entity=$1"
    },
    {
      "src": "/api/export/([^/]+)",
      "dest": "/api/export/[kind]?kind=$1"
    },
    {
      "src": "/api/operations/([^/]+)",
      "dest": "/api/operations/[action]?action=$1"
    },
    {
      "src": "/api/users/([^/]+)",
      "dest": "/api/users/[id]?id=$1"
    },
    {
      "src": "/api/users",
      "dest": "/api/users/[id]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
