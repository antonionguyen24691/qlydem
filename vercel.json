{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync/google-sheets",
      "schedule": "0 17 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/data/([^/]+)",
      "dest": "/api/data/[table]?table=$1"
    },
    {
      "src": "/api/import/([^/]+)",
      "dest": "/api/import/[entity]?entity=$1"
    },
    {
      "src": "/api/templates/([^/]+)",
      "dest": "/api/templates/[entity]?entity=$1"
    },
    {
      "src": "/api/export/([^/]+)",
      "dest": "/api/export/[kind]?kind=$1"
    },
    {
      "src": "/api/operations/([^/]+)",
      "dest": "/api/operations/[action]?action=$1"
    },
    {
      "src": "/api/users/([^/]+)",
      "dest": "/api/users/[id]?id=$1"
    },
    {
      "src": "/api/users",
      "dest": "/api/users/[id]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
