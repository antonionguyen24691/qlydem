# Public app URL
APP_BASE_URL="http://localhost:3000"

# Supabase: server-side only key must never be exposed to browser bundles.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Google Sheets sync target.
GOOGLE_SHEETS_SPREADSHEET_ID="your-google-sheet-id"
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Protect internal export/sync endpoints. Send as x-internal-secret.
INTERNAL_API_SECRET="change-me-long-random-secret"

# Optional AI and notification integrations.
GEMINI_API_KEY=""
TELEGRAM_BOT_TOKEN=""
